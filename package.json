{
  "name": "zenfit",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "web": "expo start --web",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts' '__tests__/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'App.tsx' 'index.ts'",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "validate": "npm run typecheck && npm run lint && npm run test",
    "docs": "typedoc",
    "docs:pages": "typedoc && echo 'Docs generated in docs/api/ → served at https://iamjeerge.github.io/zenfit/'",
    "postinstall": "node scripts/fix-rn-jest-mocks.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@supabase/supabase-js": "^2.99.3",
    "react": "19.2.0",
    "react-dom": "^19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^4.2.3",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/jest-preset": "^0.85.0-nightly-20260219-44901aaf9",
    "@react-native/metro-config": "^0.84.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "babel-jest": "^30.3.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
