# ─────────────────────────────────────────────────
# ZenFit — Environment Variables
# Copy this to .env and NEVER commit it to git
# ─────────────────────────────────────────────────

# Supabase — get from: supabase.com → Project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude AI — for food recommendations
EXPO_PUBLIC_CLAUDE_API_KEY=your-claude-api-key

# Stripe — for subscriptions
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-key
